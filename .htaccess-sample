# eu=Basque, be=Belarusian, bn=Bengali, bs=Bosnian, bg=Bulgarian, ca=Catalan,
# ceb=Cebuano, ny=Chichewa, zh-CN=Chinese (Simplified), zh-TW=Chinese (Traditional),
